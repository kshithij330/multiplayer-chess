{
  "name": "chess-app",
  "version": "1.0.0",
  "description": "Full-featured chess application with multiplayer lobbies, AI bots, and timers",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "start": "node server/index.js",
    "dev:server": "node server/index.js",
    "dev:client": "cd client && npm run dev",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "chess.js": "^1.1.0",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "js-chess-engine": "^1.0.2",
    "socket.io": "^4.8.1",
    "uuid": "^9.0.1"
  }
}
